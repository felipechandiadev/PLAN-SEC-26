{
  "arquitectura_desarrollo": {
    "proyecto": "Parral Seguro 2026 - Matriz Operativa",
    "tipo": "SPA (Single Page Application) con Vite + Vanilla JS",
    "objetivo": "Visualizar planificación anual con múltiples vistas (Gantt, Calendario, Detalles)",
    
    "structure_carpetas": {
      "src/": {
        "components/": {
          "descripcion": "Componentes reutilizables",
          "archivos": [
            "Header.js - Encabezado con branding PSP",
            "Legend.js - Leyenda de colores y estamentos",
            "Navigation.js - Barra de navegación entre vistas",
            "DateBadge.js - Badge de fecha con color de institución",
            "JustificationBox.js - Caja de justificación técnica"
          ]
        },
        "views/": {
          "descripcion": "Vistas principales de la aplicación",
          "archivos": [
            "MatrizGanttView.js - Vista principal (Matriz anual integrada)",
            "CalendarioMesView.js - Vista calendario por mes",
            "DetallesOperativoView.js - Detalles de operativo específico",
            "DashboardView.js - Panel de control / resumen anual"
          ]
        },
        "data/": {
          "descripcion": "Datos y estructuras",
          "archivos": [
            "operativos.js - Array de actividades/operativos",
            "meses.js - Configuración de meses y programas",
            "instituciones.js - Mapa de instituciones y colores",
            "constantes.js - URLs, constantes globales"
          ]
        },
        "styles/": {
          "descripcion": "Estilos globales y variables",
          "archivos": [
            "main.css - Estilos globales",
            "gantt.css - Estilos específicos para matriz",
            "calendar.css - Estilos para calendario",
            "variables.css - Variables CSS compartidas"
          ]
        },
        "utils/": {
          "descripcion": "Funciones y utilidades",
          "archivos": [
            "router.js - Sistema de enrutamiento simple",
            "dateUtils.js - Manipulación de fechas",
            "colorMap.js - Mapeo de instituciones a colores",
            "dataTransform.js - Transformación de datos para vistas"
          ]
        },
        "archivos_raiz": [
          "main.js - Punto de entrada",
          "App.js - Componente aplicación principal"
        ]
      }
    },

    "rutas_planificadas": {
      "/": "Vista Principal - Matriz Gantt Operativa Anual",
      "/calendario/:mes": "Vista Calendario Mensual (ej: /calendario/enero)",
      "/operativo/:id": "Detalle de un operativo específico",
      "/dashboard": "Resumen ejecutivo anual",
      "/estadisticas": "Análisis y reportes (futuro)"
    },

    "caracteristicas_principales": {
      "vista_1_matriz_gantt": {
        "nombre": "PLANIFICACIÓN ANUAL DIRECCIÓN DE SEGURIDAD PÚBLICA MUNICIPAL",
        "descripcion": "Visualización horizontal de planificación anual",
        "componentes": [
          "Encabezado con branding PSP",
