          "Filtrado de operativos para ese mes",
          "Indicadores visuales por institución"
        ],
        "funcionalidad": [
          "Click en día muestra operativos",
          "Navegación prev/next mes",
          "Resaltado de hoy"
        ]
      },

      "vista_3_detalles": {
        "nombre": "Detalles de Operativo",
        "descripcion": "Panel con info completa de un operativo",
        "campos": [
          "Nombre operativo",
          "Institución responsable",
          "Color institución",
          "Fechas de ejecución",
          "Justificación técnica completa",
          "Contexto territorial"
        ]
      },

      "vista_4_dashboard": {
        "nombre": "Dashboard Ejecutivo",
        "descripcion": "Resumen visual anual",
        "elementos": [
          "Total operativos por mes",
          "Distribución por institución",
          "Heatmap: intensidad de actividades",
          "KPIs: días operativos, meses cubiertos",
          "Gráficos simples"
        ]
      }
    },

    "manejo_estado": {
      "metodo": "Store simple (sin frameworks)",
      "datos_globales": [
        "Mes seleccionado actual",
        "Vista activa (gantt / calendario / detalles)",
        "Operativo seleccionado (null o ID)",
