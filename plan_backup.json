    "componentes_reutilizables": {
      "Header": {
        "props": ["titulo", "subtitulo", "logoText"],
        "ejemplo": "Encabezado con PSP + título + estado validación"
      },
      "Legend": {
        "props": ["instituciones"],
        "ejemplo": "7 filas con color + nombre estamento"
      },
      "DateBadge": {
        "props": ["date", "institucionColor"],
        "ejemplo": "pequeño círculo/cuadrado con número"
      },
      "JustificationBox": {
        "props": ["texto"],
        "ejemplo": "Caja amarillenta con contexto de decisión"
      },
      "MonthHeader": {
        "props": ["mesNombre", "programa"],
        "ejemplo": "Encabezado columna con mes + programa"
      },
      "Navigation": {
        "props": ["currentView", "onNavigate"],
        "ejemplo": "Barra con botones: Matriz, Calendario, Dashboard"
      }
    },

    "flujo_desarrollo_fase_1": [
      "1. Refactorizar HTML/CSS a componentes JS modulares",
      "2. Crear sistema de enrutamiento simple",
      "3. Implementar vista Matriz Gantt (copiar HTML original)",
      "4. Crear estructura de datos centralizada (operativos.js)",
      "5. Implementar componentes Header, Legend, Navigation",
      "6. Validar que matriz funcione con datos dinámicos"
    ],

    "flujo_desarrollo_fase_2": [
      "7. Crear CalendarioMesView.js con grilla día x semana",
      "8. Implementar navegación mes anterior/siguiente",
      "9. Filtrar operativos por mes en calendario",
      "10. Crear vista DetallesOperativoView.js",
      "11. Enlazar clicks entre vistas"
    ],

    "flujo_desarrollo_fase_3": [
      "12. Crear DashboardView.js con estadísticas",
      "13. Implementar gráficos simples (Chart.js o vanilla)",
      "14. Refinar estilos responsivos",
      "15. Testing en diferentes resoluciones"
    ]
  },

